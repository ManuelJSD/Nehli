# ============================================
# Nehli Backend — Variables de Entorno
# ============================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees el archivo .env al repositorio.
# ============================================

# ─── Servidor ───────────────────────────────
PORT=3000
HOST=localhost
# Entorno: development | production
NODE_ENV=development

# ─── Base de datos MySQL ─────────────────────
MYSQL_HOST=localhost
MYSQL_DATABASE=nehli
MYSQL_USER=root
MYSQL_PASSWORD=

# ─── JWT ─────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_UN_SECRETO_LARGO_Y_ALEATORIO

# ─── SMTP (Email) ─────────────────────────────
# Para Gmail, usar una "App Password" en: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password-de-gmail
SMTP_FROM=no-reply@nehli.com

# ─── CORS ────────────────────────────────────
# Orígenes permitidos, separados por coma si son varios
# Ej: http://localhost:4200,https://nehli.midominio.com
CORS_ORIGIN=http://localhost:4200

# ─── Rutas de medios ──────────────────────────
# Ruta absoluta o relativa a la carpeta de videos
# Estructura esperada: VIDEO_FOLDER/Peliculas/Titulo/video.mp4
VIDEO_FOLDER=./videos

# Ruta absoluta o relativa a la carpeta de música
# Estructura esperada: MUSIC_FOLDER/Artista/cancion.mp3
MUSIC_FOLDER=./musica